{
  "name": "cloudflare-reminder",
  "version": "0.1.24",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "wrangler dev",
    "frontend:dev": "vite dev",
    "deploy": "npm run build && wrangler deploy --config wrangler.local.toml",
    "deploy:public-config": "npm run build && wrangler deploy",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "release:push": "node scripts/release-push.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.app.json --noEmit",
    "check:readiness": "node scripts/check-readiness.mjs",
    "config:email": "node scripts/configure-email.mjs",
    "seed:make": "node scripts/make-seed.mjs",
    "d1:create": "wrangler d1 create personal-reminder",
    "d1:migrate:local": "wrangler d1 migrations apply personal-reminder --local",
    "d1:migrate:remote": "wrangler d1 migrations apply personal-reminder --remote --config wrangler.local.toml",
    "tail": "wrangler tail --config wrangler.local.toml"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "postal-mime": "^2.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260605.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.20.0"
  }
}
